{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ane Racing PRO",
  "version": "0.1.0",
  "identifier": "dev.nkvoll.ane-racing-pro",
  "build": {
    "frontendDist": "../web",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "python3 -m http.server 1420 --bind 127.0.0.1 --directory web",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Ane Racing PRO",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
